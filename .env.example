# ============================================================
# SCORCHED — Environment Configuration
# Copy to .env and customize for your deployment
# ============================================================

# ==========================================================
# X LAYER CONNECTION
# ==========================================================

# X Layer HTTP JSON-RPC endpoint (for eth_call, eth_getLogs, backfill)
# Mainnet: https://rpc.xlayer.tech or https://xlayerrpc.okx.com
# Testnet: https://testrpc.xlayer.tech/terigon
XLAYER_RPC=https://rpc.xlayer.tech

# X Layer WebSocket endpoint (REQUIRED for real-time eth_subscribe — the HTTP
# endpoint above does NOT support subscriptions, this is a separate connection)
# Mainnet: wss://xlayerws.okx.com or wss://ws.xlayer.tech
XLAYER_WS=wss://xlayerws.okx.com

# Note: public RPC has a 100 req/s per-IP limit. For production indexing volume,
# use a dedicated provider (QuickNode, Chainstack, BlockPI, etc.) — see X Layer docs.

# Starting block for backfill (0 = genesis, or set to recent block)
START_BLOCK=0

# Block confirmations required before treating an event as final.
# VERIFY this against current X Layer finality guarantees before relying on it —
# do not assume a specific number without checking current docs/status.
BLOCK_CONFIRMATIONS=1

# ==========================================================
# CONTRACT ADDRESSES (X Layer Mainnet)
# ==========================================================

# ERC-8004 Identity Registry
# CONFIRMED LIVE on X Layer (verified via 8004scan.io networks page):
#   Identity Registry:   0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
#   Reputation Registry: 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# Same deterministic address as Ethereum/Base/BSC/etc. 4,830+ agents already
# registered on X Layer as of this check. Uncomment to use:
# ERC8004_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_REGISTRY=

# Agent Payments Protocol / ERC-8183 (Agentic Commerce) escrow contract
# ERC-8183 is real (OKX Wallet is an official co-author) with a CC0 reference
# implementation (AgenticCommerce + IACPHook). No universal canonical escrow
# singleton exists yet (unlike ERC-8004 identity), but a real, verifiable
# deployment on X Layer mainnet does exist, from the open-source CivilisAI
# project (MIT licensed, github.com/CivilisAI/Civilis-public):
#   ACPV2 (their ERC-8183 contract): 0xBEf97c569a5b4a82C1e8f53792eC41c988A4316e
#   CivilisCommerceV2 (wrapper):     0x7bac782C23E72462C96891537C61a4C86E9F086e
# This is ONE project's own deployment, not an X-Layer-wide standard — real
# on-chain activity, but scoped to their world. Verify current state on
# OKX's explorer before using: web3.okx.com/explorer/x-layer/address/<addr>
# Uncomment to use as a working example:
# APP_PROTOCOL=0xBEf97c569a5b4a82C1e8f53792eC41c988A4316e
# The indexer's ABI must match ERC-8183's real Job lifecycle
# (Open → Funded → Submitted → Terminal), not the old fabricated
# QuoteIssued/EscrowOpened events — see AUDIT.md.
APP_PROTOCOL=

# OKB Token (Gas Token)
OKB_TOKEN=0x75231f58b43240c9718dd58b4967c5114342a86c

# USDC on X Layer
USDC_TOKEN=0x74b7f16337b8972027f6196a17a631ac6de26d22

# ==========================================================
# DATABASE — PostgreSQL
# ==========================================================

POSTGRES_PASSWORD=scorched_secure_2024
POSTGRES_DSN=postgres://scorched:scorched_secure_2024@postgres:5432/scorched?sslmode=disable

# ==========================================================
# GRAPH DATABASE — Neo4j
# ==========================================================

NEO4J_AUTH=neo4j/scorched_graph_2024
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scorched_graph_2024

# ==========================================================
# CACHE — Redis
# ==========================================================

REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# ==========================================================
# API SERVER
# ==========================================================

API_PORT=8080
# Turn off in production — exposes full GraphQL schema introspection
ENABLE_PLAYGROUND=true
# Comma-separated allowlist. Do NOT use "*" combined with credentials in production.
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=100

# ==========================================================
# FRONTEND
# ==========================================================

FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080
REACT_APP_XLAYER_EXPLORER=https://www.oklink.com/xlayer

# ==========================================================
# MONITORING
# ==========================================================

GRAFANA_PASSWORD=scorched_dashboard
GRAFANA_PORT=3001

# ==========================================================
# LOGGING
# ==========================================================

LOG_LEVEL=info
LOG_FORMAT=json

# ==========================================================
# SCORCHED ASP CONFIG (Self-reputation)
# ==========================================================

# Scorched's own ERC-8004 ID (set after registration)
SCORCHED_AGENT_ID=

# Bond amount for attestation staking (OKB wei)
SCORCHED_BOND_AMOUNT=100000000000000000000

# Attestation validity period (hours)
ATTESTATION_TTL=168
